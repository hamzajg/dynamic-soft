# Server
HOST=0.0.0.0
PORT=8083

# Output
OUTPUT_DIR=/home/kali/Downloads/dynamic-soft/output

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3010

# Ollama
OLLAMA_BASE_URL=http://localhost:8000
OLLAMA_API_KEY=

# Analysis
ANALYSIS_ENABLED=true
FRAME_ANALYZER_MODE=single
FRAME_ANALYZER_BACKEND=ollama
FRAME_ANALYZER_MODEL=llava
FRAME_ANALYZER_BATCH_MODEL=llama3.2-vision

# Opencode
ANALYSIS_OPENCODE_MODEL=opencode/big-pickle
ANALYSIS_OPENCODE_FLAGS=--dangerously-skip-permissions
